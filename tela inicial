st.markdown(f"""
<div class="topo">
    <h1>🌱 EcoTech Solutions</h1>
    <p>Sistema inteligente para monitoramento de energia, resíduos e sustentabilidade</p>
    <p><b>Perfil ativo:</b> {perfil}</p>
</div>
""", unsafe_allow_html=True)

# =========================
# ALERTAS
# =========================
if volume_residuos >= limite_residuos:
    st.error("⚠️ Alerta de coleta: o limite de resíduos foi atingido.")
elif volume_residuos >= limite_residuos * 0.85:
    st.warning("⚠️ Atenção: o volume de resíduos está próximo do limite.")
else:
    st.success("✅ Resíduos em nível controlado.")

if consumo_atual > meta_consumo:
    st.warning("⚡ Consumo energético acima da meta estabelecida.")
else:
    st.success("⚡ Consumo energético dentro da meta.")

# =========================
# CARDS DE INDICADORES
# =========================
col1, col2, col3, col4 = st.columns(4)

with col1:
    st.markdown(f"""
    <div class="card">
        <h3>Consumo Atual</h3>
        <p>{consumo_atual} kWh</p>
    </div>
    """, unsafe_allow_html=True)

with col2:
    st.markdown(f"""
    <div class="card">
        <h3>Meta de Consumo</h3>
        <p>{meta_consumo} kWh</p>
    </div>
    """, unsafe_allow_html=True)

with col3:
    st.markdown(f"""
    <div class="card">
        <h3>Resíduos Gerados</h3>
        <p>{volume_residuos} L</p>
    </div>
    """, unsafe_allow_html=True)

with col4:
    st.markdown(f"""
    <div class="card">
        <h3>Eficiência Energética</h3>
        <p>{eficiencia}%</p>
    </div>
    """, unsafe_allow_html=True)

# =========================
# GRÁFICOS
# =========================
st.markdown('<div class="subtitulo">📈 Monitoramento Semanal</div>', unsafe_allow_html=True)
g1, g2 = st.columns(2)

with g1:
    fig_consumo = px.line(
        historico,
        x="Dia",
        y="Consumo (kWh)",
        markers=True,
        title="Histórico de Consumo Energético"
    )
    fig_consumo.update_layout(
        xaxis_title="Dia da Semana",
        yaxis_title="kWh",
        template="plotly_white"
    )
    st.plotly_chart(fig_consumo, use_container_width=True)

with g2:
    fig_residuos = px.bar(
        historico,
        x="Dia",
        y="Resíduos (L)",
        title="Volume de Resíduos"
    )
    fig_residuos.update_layout(
        xaxis_title="Dia da Semana",
        yaxis_title="Litros",
        template="plotly_white"
    )
    st.plotly_chart(fig_residuos, use_container_width=True)

# =========================
# MEDIDORES
# =========================
st.markdown('<div class="subtitulo">🎯 Indicadores Inteligentes</div>', unsafe_allow_html=True)
m1, m2 = st.columns(2)

with m1:
    fig_gauge_eficiencia = go.Figure(go.Indicator(
        mode="gauge+number",
        value=eficiencia,
        title={'text': "Eficiência Energética"},
        gauge={
            'axis': {'range': [0, 100]},
            'steps': [
                {'range': [0, 50], 'color': "#d8f3dc"},
                {'range': [50, 80], 'color': "#95d5b2"},
                {'range': [80, 100], 'color': "#40916c"}
            ]
        }
    ))
    st.plotly_chart(fig_gauge_eficiencia, use_container_width=True)

with m2:
    percentual_residuos = (volume_residuos / limite_residuos) * 100
    fig_gauge_residuos = go.Figure(go.Indicator(
        mode="gauge+number",
        value=percentual_residuos,
        title={'text': "Capacidade dos Resíduos"},
        gauge={
            'axis': {'range': [0, 100]},
            'steps': [
                {'range': [0, 60], 'color': "#d8f3dc"},
                {'range': [60, 85], 'color': "#ffd166"},
                {'range': [85, 100], 'color': "#ef476f"}
            ]
        }
    ))
    st.plotly_chart(fig_gauge_residuos, use_container_width=True)

