# =========================
# DADOS SIMULADOS
# =========================
consumo_atual = 128.5
meta_consumo = 100.0
volume_residuos = 72
limite_residuos = 80
eficiencia = 84
equipamentos_ativos = 14

historico = pd.DataFrame({
    "Dia": ["Seg", "Ter", "Qua", "Qui", "Sex", "Sáb", "Dom"],
    "Consumo (kWh)": [95, 102, 98, 120, 110, 90, 88],
    "Resíduos (L)": [40, 45, 50, 55, 60, 62, 72]
})

# =========================
# MENU LATERAL
# =========================
st.sidebar.image("https://cdn-icons-png.flaticon.com/512/2909/2909761.png", width=80)
st.sidebar.title("EcoTech Solutions")
st.sidebar.markdown("### Navegação")
st.sidebar.write("🏠 Dashboard")
st.sidebar.write("⚡ Consumo Energético")
st.sidebar.write("🗑️ Resíduos")
st.sidebar.write("📊 Relatórios")
st.sidebar.write("⚙️ Configurações")

perfil = st.sidebar.selectbox(
    "Tipo de usuário",
    ["Administrador", "Técnico", "Usuário Comum"]
)

st.sidebar.markdown("---")
st.sidebar.info("Sistema de monitoramento sustentável em tempo real.")

# =========================
# TOPO
